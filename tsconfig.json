{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "isolatedModules": true
  },
  "include": ["src", "vite.config.js", "playwright.config.js"],
  "exclude": ["dist", "node_modules"]
}
