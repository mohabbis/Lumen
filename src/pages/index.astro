---
import BaseHead from '../components/BaseHead.astro';
import logoUrl from '../../CarWashGuys-LOGO.svg?url';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const address = '2918 Washington Rd, Kenosha, WI';
const mapsUrl = 'https://www.google.com/maps/search/?api=1&query=2918%20Washington%20Rd%20Kenosha%20WI';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image={logoUrl} />
	</head>
	<body>
		<div class="site-shell">
			<header class="nav" aria-label="Primary navigation">
				<a class="brand" href="/" aria-label="Car Wash Guys home">
					<img src={logoUrl} alt="Car Wash Guys" />
				</a>
				<nav>
					<a href="#services">Services</a>
					<a href="#location">Location</a>
					<a href="#updates">Updates</a>
				</nav>
			</header>

			<main>
				<section class="hero" aria-labelledby="hero-title">
					<div class="hero-copy">
						<p class="eyebrow">Coming soon to Kenosha</p>
						<h1 id="hero-title">A clean, local car wash built for Washington Road.</h1>
						<p class="hero-text">
							Car Wash Guys is preparing a practical, friendly wash experience at 2918 Washington Rd in Kenosha, Wisconsin.
							The first site version is live while launch details, hours, pricing, and service packages are finalized.
						</p>
						<div class="hero-actions">
							<a class="button primary" href={mapsUrl} target="_blank" rel="noreferrer">View location</a>
							<a class="button secondary" href="#updates">Follow launch status</a>
						</div>
					</div>
					<div class="hero-card" aria-label="Car Wash Guys launch card">
						<img src={logoUrl} alt="" class="hero-logo" />
						<div class="status-pill">Under construction</div>
						<p>{address}</p>
					</div>
				</section>

				<section class="section split" id="services" aria-labelledby="services-title">
					<div>
						<p class="eyebrow">Wash experience</p>
						<h2 id="services-title">Built around the essentials first.</h2>
					</div>
					<p>
						Service details are being finalized. This landing page keeps the public promise simple:
						make the location easy to find, explain what is coming, and avoid inventing fake pricing like a desperate coupon flyer.
					</p>
				</section>

				<section class="cards" aria-label="Planned service areas">
					<article>
						<span>01</span>
						<h3>Exterior wash</h3>
						<p>Core wash packages will be listed once final equipment, pricing, and package names are confirmed.</p>
					</article>
					<article>
						<span>02</span>
						<h3>Membership ready</h3>
						<p>The site is structured to support future membership links, account flows, or provider-hosted checkout.</p>
					</article>
					<article>
						<span>03</span>
						<h3>Local convenience</h3>
						<p>Clear mobile calls-to-action, location visibility, and simple updates for Kenosha drivers nearby.</p>
					</article>
				</section>

				<section class="location-panel" id="location" aria-labelledby="location-title">
					<div>
						<p class="eyebrow">Find us</p>
						<h2 id="location-title">2918 Washington Rd</h2>
						<p>Kenosha, WI</p>
					</div>
					<a class="button primary" href={mapsUrl} target="_blank" rel="noreferrer">Open in maps</a>
				</section>

				<section class="section launch" id="updates" aria-labelledby="updates-title">
					<p class="eyebrow">Launch status</p>
					<h2 id="updates-title">The public site is being staged now.</h2>
					<div class="timeline">
						<div>
							<strong>Now</strong>
							<p>Brand, location, and coming-soon landing page.</p>
						</div>
						<div>
							<strong>Next</strong>
							<p>Add confirmed hours, phone, pricing, wash packages, photos, and launch announcement copy.</p>
						</div>
						<div>
							<strong>Later</strong>
							<p>Connect memberships, promotions, reviews, local SEO pages, and fleet or business inquiries.</p>
						</div>
					</div>
				</section>
			</main>

			<footer class="footer">
				<p>Car Wash Guys</p>
				<p>{address}</p>
			</footer>
		</div>
	</body>
</html>
